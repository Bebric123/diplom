# Скопируйте в .env и подставьте значения (файл .env в git не коммитится).
# Полный список: project/backend/src/core/config.py

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=Monitoring
DATABASE_URL=postgresql://postgres:postgres@db:5432/Monitoring
REDIS_URL=redis://redis:6379/0

TELEGRAM_BOT_TOKEN=your-bot-token-from-BotFather
# TELEGRAM_CHAT_ID=  # опционально, для отчётов

# Анализ ошибок: из контейнеров backend/worker — НЕ 127.0.0.1 (это внутри контейнера), а:
#   host.docker.internal:ПОРТ — Windows/macOS Docker Desktop, сервис на вашем ПК
# Open WebUI: :3000 и путь /api/chat/completions. LM Studio local server: часто :1234 и
#   OPEN_WEBUI_CHAT_COMPLETIONS_PATH=/v1/chat/completions
ERROR_ANALYSIS_BACKEND=open_webui
OPEN_WEBUI_BASE_URL=http://host.docker.internal:3000
OPEN_WEBUI_MODEL=
# OPEN_WEBUI_API_KEY=
# OPEN_WEBUI_CHAT_COMPLETIONS_PATH=/api/chat/completions
# OPEN_WEBUI_MAX_TOKENS=1024
# OPEN_WEBUI_TEMPERATURE=0.22
# Медленная модель / CPU — 600+; в docker/.env: OPEN_WEBUI_TIMEOUT_SEC=600
# OPEN_WEBUI_TIMEOUT_SEC=420
# off = только текст промпта (по умолчанию; у LM Studio json_object даёт 400)
# json_object / json_schema — response_format в API, если бэкенд поддерживает
# OPEN_WEBUI_RESPONSE_FORMAT=off
# false = не дописывать /no_think в конец промпта (Qwen3 thinking: отключает reasoning)
# OPEN_WEBUI_NO_THINK=true
# ERROR_ANALYSIS_BACKEND=none

# Автоудаление событий и загруженных логов (Celery beat, ежедневно)
DATA_RETENTION_ENABLED=true
DATA_RETENTION_DAYS=365
DATA_RETENTION_CRON_HOUR=3
DATA_RETENTION_CRON_MINUTE=20

# Периодические отчёты в чат проекта (Celery beat) + то же окно в /stats, /report
WEEKLY_REPORT_ENABLED=true
STATS_REPORT_RANGE_DAYS=7
# Расписание: interval — каждые N суток; cron — пн 08:00 UTC (как раньше)
STATS_REPORT_BEAT_MODE=cron
STATS_REPORT_BEAT_INTERVAL_DAYS=7
STATS_REPORT_BEAT_CRON_MINUTE=0
STATS_REPORT_BEAT_CRON_HOUR=8
STATS_REPORT_BEAT_CRON_DAY_OF_WEEK=mon
# Пример: раз в 5 суток вместо «по понедельникам»:
# STATS_REPORT_BEAT_MODE=interval
# STATS_REPORT_BEAT_INTERVAL_DAYS=5

# Троттлинг повторных алертов в Telegram (секунды, одна error_group + тот же severity)
ALERT_THROTTLE_LOW_SEC=3600
ALERT_THROTTLE_MEDIUM_SEC=1800
ALERT_THROTTLE_HIGH_SEC=900
ALERT_THROTTLE_CRITICAL_SEC=300
ALERT_THROTTLE_DEFAULT_SEC=1800

# CELERY_WORKER_CONCURRENCY=1
