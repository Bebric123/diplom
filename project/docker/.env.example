# Скопируйте в .env и подставьте значения (файл .env в git не коммитится).
# Полный список: project/backend/src/core/config.py

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=Monitoring
DATABASE_URL=postgresql://postgres:postgres@db:5432/Monitoring
REDIS_URL=redis://redis:6379/0

TELEGRAM_BOT_TOKEN=your-bot-token-from-BotFather
# TELEGRAM_CHAT_ID=  # опционально, для отчётов

# Анализ ошибок для Telegram → Open WebUI на хосте
ERROR_ANALYSIS_BACKEND=open_webui
OPEN_WEBUI_BASE_URL=http://host.docker.internal:3000
OPEN_WEBUI_MODEL=
# OPEN_WEBUI_API_KEY=
# OPEN_WEBUI_CHAT_COMPLETIONS_PATH=/api/chat/completions
# OPEN_WEBUI_MAX_TOKENS=512
# OPEN_WEBUI_TIMEOUT_SEC=180
# OPEN_WEBUI_REQUEST_JSON_OBJECT=true
# ERROR_ANALYSIS_BACKEND=none

# Автоудаление событий и загруженных логов (Celery beat, ежедневно ~03:20 UTC)
DATA_RETENTION_ENABLED=true
DATA_RETENTION_DAYS=365

# CELERY_WORKER_CONCURRENCY=1
