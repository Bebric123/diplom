# Скопируйте в .env и подставьте значения (файл .env в git не коммитится).
# Полный список: project/backend/src/core/config.py

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=Monitoring
DATABASE_URL=postgresql://postgres:postgres@db:5432/Monitoring
REDIS_URL=redis://redis:6379/0

TELEGRAM_BOT_TOKEN=your-bot-token-from-BotFather
# TELEGRAM_CHAT_ID=  # опционально, для отчётов

# Локальный ИИ (air-gap по данным ошибок: без облачных LLM)
# LOCAL_LLM_GGUF_PATH=/models/model.gguf
# ERROR_ANALYSIS_BACKEND=local_gguf
# ERROR_ANALYSIS_BACKEND=none

# Скорость CPU: true — ужимает max_tokens и лимит при JSON-грамматике (см. README backend)
LOCAL_LLM_FAST_MODE=true
LOCAL_LLM_MAX_TOKENS=384
LOCAL_LLM_N_CTX=8192
LOCAL_LLM_JSON_GRAMMAR=true
LOCAL_LLM_REPEAT_PENALTY=1.18

# CELERY_WORKER_CONCURRENCY=1
