# Скопируйте в .env и подставьте значения (см. project/docker/.env или http://127.0.0.1:8000/register).
# Для демо из сида: MONITOR_PROJECT_ID=00000000-0000-4000-8000-000000000001, MONITOR_API_KEY=dev-demo-ingest-key
# Можно использовать префикс VITE_ (как в React) — bootstrap_local_env.php сопоставит с MONITOR_*.

MONITOR_URL=http://127.0.0.1:8000
MONITOR_PROJECT_ID=00000000-0000-4000-8000-000000000001
MONITOR_API_KEY=dev-demo-ingest-key
